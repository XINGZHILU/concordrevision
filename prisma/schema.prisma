generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model User {
    id                 String                    @id @default(cuid())
    email              String                    @unique
    firstname          String?
    lastname           String?
    teacher            Boolean                   @default(false)
    admin              Boolean                   @default(false)
    upload_permission  Boolean                   @default(false)
    check_waiver       Boolean                   @default(false)
    year               Int                       @default(-1)
    // posts              Post[]
    notes              Note[]
    olympiad_resources Olympiad_Resource[]
    ppq_records        PastPaperRecord[]
    ucasPosts          UCASPost[]
    subscriptions      UserSubjectSubscription[]
    colourLinks        ColourLink[]
}

enum Colour {
    Unclassified
    Red
    Amber
    Green
}

model ColourLink {
    id        Int     @id @default(autoincrement())
    user      User    @relation(fields: [userId], references: [id])
    userId    String
    subject   Subject @relation(fields: [subjectId], references: [id])
    subjectId Int
    note      Note    @relation(fields: [noteId], references: [id])
    noteId    Int
    colour    Colour
}

model Subject {
    id          Int                       @id @default(autoincrement())
    title       String
    desc        String
    level       Int // 0 = F3, 1 = F4, etc.
    notes       Note[]
    tests       Test[]
    ppq_records PastPaperRecord[]
    subscribers UserSubjectSubscription[]
    colourLinks ColourLink[]
}

model UserSubjectSubscription {
    id                    Int     @id @default(autoincrement())
    userId                String
    user                  User    @relation(fields: [userId], references: [id])
    subjectId             Int
    subject               Subject @relation(fields: [subjectId], references: [id])
    test_notification     Boolean @default(true)
    resource_notification Boolean @default(false)
}

model Test {
    id        Int      @id @default(autoincrement())
    title     String
    type      Int      @default(0) // 0 = Sat Test, 1 = EOT Exam, 2 = External Exam
    subject   Subject  @relation(fields: [subjectId], references: [id])
    subjectId Int
    desc      String   @default("")
    topics    String[]
    notes     Note[]
    date      DateTime @default(now()) @db.Date
}

model Note {
    id          Int           @id @default(autoincrement())
    title       String
    subject     Subject       @relation(fields: [subjectId], references: [id])
    subjectId   Int
    desc        String        @default("")
    author      User          @relation(fields: [authorId], references: [id])
    authorId    String
    type        Int           @default(2) // 0 = Internal Exam Note, 1 = External Exam, 2 = Other
    test        Test?         @relation(fields: [testId], references: [id])
    testId      Int?
    pinned      Boolean       @default(false)
    approved    Boolean       @default(false)
    files       StorageFile[]
    uploadedAt  DateTime      @default(now())
    colourLinks ColourLink[]
}

model Olympiad {
    id                Int                 @id @default(autoincrement())
    title             String
    area              String
    links             String[]
    link_descriptions String[]
    desc              String              @default("")
    resources         Olympiad_Resource[]
}

model Olympiad_Resource {
    id         Int           @id @default(autoincrement())
    title      String
    desc       String        @default("")
    olympiad   Olympiad      @relation(fields: [olympiadId], references: [id])
    olympiadId Int
    author     User          @relation(fields: [authorId], references: [id])
    authorId   String
    type       Int           @default(0)
    files      StorageFile[]
    approved   Boolean       @default(false)
    pinned     Boolean       @default(false)
    uploadedAt DateTime      @default(now())
}

model StorageFile {
    id                Int                @id @default(autoincrement())
    filename          String
    type              String             @default("pdf")
    path              String
    note              Note?              @relation(fields: [noteId], references: [id])
    noteId            Int?
    olympiad_resource Olympiad_Resource? @relation(fields: [olympiadId], references: [id])
    olympiadId        Int?
    ucasPost          UCASPost?          @relation(fields: [ucasPostId], references: [id])
    ucasPostId        Int?
}

model PastPaperRecord {
    id              String  @id @default(cuid())
    name            String
    user            User    @relation(fields: [userId], references: [id])
    userId          String
    subject         Subject @relation(fields: [subjectId], references: [id])
    subjectId       Int
    specimen        Boolean @default(true)
    start_year      Int     @default(2015)
    end_year        Int     @default(2025)
    paper_count     Int     @default(3)
    papers_finished Int[]
    paper_marks     Int[]
    max_marks       Int[]
    notes           String  @default("")
}

model UCASPost {
    id           Int           @id @default(autoincrement())
    type         Int           @default(0) // 0 = General, 1 = University Specific, 2 = UCAS Subject Specific
    title        String
    content      String        @default("")
    author       User          @relation(fields: [authorId], references: [id])
    authorId     String
    files        StorageFile[]
    approved     Boolean       @default(false)
    pinned       Boolean       @default(false)
    uploadedAt   DateTime      @default(now())
    tags         String[]
    universities String[]
    ucasSubjects String[]
}

model Tag {
    id   String @id
    name String
}

model University {
    id          String           @id
    name        String
    uk          Boolean
    courses     Course[]
    description String           @default("")
    stats       AdmissionStats[]
}

enum UCASSubjectType {
    STEM
    Law_Humanities
    Languages
    Medicine
    Art
}

model UCASSubject {
    id          String            @id
    name        String
    courses     Course[]
    type        UCASSubjectType
    description String            @default("")
}

model Course {
    id                 Int          @id @default(autoincrement())
    university         University   @relation(fields: [universityId], references: [id])
    universityId       String
    ucasSubject        UCASSubject  @relation(fields: [ucasSubjectId], references: [id])
    ucasSubjectId      String
    name               String
    entry_requirements String       @default("")
    description        String       @default("")
    ucascode           String
    duration           Int
    qualification      String
    url                String?
}

model AdmissionStats {
    id           Int        @id @default(autoincrement())
    university   University @relation(fields: [universityId], references: [id])
    universityId String
    applied      Int
    accepted     Int
    year         Int

    @@unique([universityId, year])
}
