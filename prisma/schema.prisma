generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id      String  @id @default(cuid())
  email   String  @unique
  name    String?
  teacher Boolean @default(false)
  year    Int     @default(-1)
  posts   Post[]
  notes   Note[]
}

model Subject {
  id    Int    @id @default(autoincrement())
  title String
  desc  String
  level Int // 0 = F3, 1 = F4, etc.
  notes Note[]
}

model Activity {
  id       Int    @id @default(autoincrement())
  title    String
  desc     String
  filename String
  posts    Post[]
}

model Note {
  id        Int     @id @default(autoincrement())
  title     String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int
  desc      String
  filename  String
  author    User    @relation(fields: [authorId], references: [id])
  authorId  String
}

model Post {
  id         Int       @id @default(autoincrement())
  title      String
  content    String?
  published  Boolean   @default(false)
  author     User      @relation(fields: [authorId], references: [id])
  authorId   String
  Activity   Activity? @relation(fields: [activityId], references: [id])
  activityId Int?
}

model Olympiad {
  id        Int                 @id @default(autoincrement())
  title     String
  desc      String
  resources Olympiad_Resource[]
}

model Olympiad_Resource {
  id         Int      @id @default(autoincrement())
  title      String
  desc       String
  filename   String
  olympiad   Olympiad @relation(fields: [olympiadId], references: [id])
  olympiadId Int
}
