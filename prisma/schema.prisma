generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model User {
    id                 String              @id @default(cuid())
    email              String              @unique
    firstname          String?
    lastname           String?
    teacher            Boolean             @default(false)
    admin              Boolean             @default(false)
    upload_permission  Boolean             @default(false)
    year               Int                 @default(-1)
    // posts              Post[]
    notes              Note[]
    olympiad_resources Olympiad_Resource[]
    red                Int[]
    amber              Int[]
    green              Int[]
    ppq_records        PastPaperRecord[]
    ucasPosts          UCASPost[]
}

model Subject {
    id          Int               @id @default(autoincrement())
    title       String
    desc        String
    level       Int // 0 = F3, 1 = F4, etc.
    notes       Note[]
    tests       Test[]
    ppq_records PastPaperRecord[]
}

model Test {
    id        Int      @id @default(autoincrement())
    title     String
    type      Int      @default(0) // 0 = Sat Test, 1 = EOT Exam, 2 = External Exam
    subject   Subject  @relation(fields: [subjectId], references: [id])
    subjectId Int
    desc      String   @default("")
    topics    String[]
    notes     Note[]
    date      DateTime @default(now()) @db.Date
}

model Note {
    id        Int           @id @default(autoincrement())
    title     String
    subject   Subject       @relation(fields: [subjectId], references: [id])
    subjectId Int
    desc      String        @default("")
    author    User          @relation(fields: [authorId], references: [id])
    authorId  String
    type      Int           @default(2) // 0 = Internal Exam Note, 1 = External Exam, 2 = Other
    test      Test?         @relation(fields: [testId], references: [id])
    testId    Int?
    pinned    Boolean       @default(false)
    colour    Int           @default(0) // 0 = green, 1 = amber, 2 = red
    approved  Boolean       @default(false)
    files     StorageFile[]
}

model Olympiad {
    id                Int                 @id @default(autoincrement())
    title             String
    area              String
    links             String[]
    link_descriptions String[]
    desc              String              @default("")
    resources         Olympiad_Resource[]
}

model Olympiad_Resource {
    id         Int           @id @default(autoincrement())
    title      String
    desc       String        @default("")
    olympiad   Olympiad      @relation(fields: [olympiadId], references: [id])
    olympiadId Int
    author     User          @relation(fields: [authorId], references: [id])
    authorId   String
    type       Int           @default(0) // 0 = Past Paper, 1 = Solution, 2 = Other
    files      StorageFile[]
    approved   Boolean       @default(false)
}

model StorageFile {
    id                Int                @id @default(autoincrement())
    filename          String
    type              String             @default("pdf")
    path              String
    note              Note?              @relation(fields: [noteId], references: [id])
    noteId            Int?
    olympiad_resource Olympiad_Resource? @relation(fields: [olympiadId], references: [id])
    olympiadId        Int?
    ucasPost          UCASPost?          @relation(fields: [ucasPostId], references: [id])
    ucasPostId        Int?
}

model PastPaperRecord {
    id              String  @id @default(cuid())
    name            String
    user            User    @relation(fields: [userId], references: [id])
    userId          String
    subject         Subject @relation(fields: [subjectId], references: [id])
    subjectId       Int
    specimen        Boolean @default(true)
    start_year      Int     @default(2015)
    end_year        Int     @default(2025)
    paper_count     Int     @default(3)
    papers_finished Int[]
    paper_marks     Int[]
    max_marks       Int[]
    notes           String  @default("")
}

model University {
    id        String       @id
    name      String       @unique
    uk        Boolean
    courses   UcasCourse[]
    ucasPosts UCASPost[]

    @@index([name])
}

model UcasCourse {
    id                      String     @id
    name                    String
    universityId            String
    university              University @relation(fields: [universityId], references: [id], onDelete: Cascade)
    qualification           String
    duration_years          Int
    summary                 String     @db.Text
    entry_requirements_text String     @db.Text
    alevel_requirements     String?
    ib_requirements         String?
    required_subjects       String[]
    recommended_subjects    String[]
    url                     String?
    ucasPosts               UCASPost[]
    slug                    String @default("")

    @@index([universityId])
}

model UCASPost {
    id           Int           @id @default(autoincrement())
    type         Int           @default(0) // 0 = General, 1 = University Specific, 2 = Course Specific
    title        String
    content      String        @default("")
    university   University?   @relation(fields: [universityId], references: [id])
    universityId String?
    course       UcasCourse?   @relation(fields: [courseId], references: [id])
    courseId     String?
    author       User          @relation(fields: [authorId], references: [id])
    authorId     String
    files        StorageFile[]
    approved     Boolean       @default(false)
}
