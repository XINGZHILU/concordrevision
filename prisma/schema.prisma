generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id      String  @id @default(cuid())
  email   String  @unique
  name    String?
  teacher Boolean @default(false)
  year    Int     @default(-1)
  posts   Post[]
  notes   Note[]
}

model Subject {
  id    Int    @id @default(autoincrement())
  title String
  desc  String
  level Int // 0 = F3, 1 = F4, etc.
  notes Note[]
  tests Test[]
}

model Test {
  id        Int     @id @default(autoincrement())
  title     String
  sat_test  Boolean @default(false)
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int
  desc      String  @default("")
  notes     Note[]
}

model Activity {
  id    Int    @id @default(autoincrement())
  title String
  desc  String @default("")
  posts Post[]
}

model Note {
  id        Int     @id @default(autoincrement())
  title     String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int
  desc      String  @default("")
  filename  String
  author    User    @relation(fields: [authorId], references: [id])
  authorId  String
  type      Int     @default(2) // 0 = Internal Exam Note, 1 = External Exam, 2 = Other
  test      Test?   @relation(fields: [testId], references: [id])
  testId    Int?
  pinned    Boolean @default(false)
}

model Post {
  id         Int       @id @default(autoincrement())
  title      String
  content    String?
  published  Boolean   @default(false)
  author     User      @relation(fields: [authorId], references: [id])
  authorId   String
  Activity   Activity? @relation(fields: [activityId], references: [id])
  activityId Int?
}

model Olympiad {
  id        Int                 @id @default(autoincrement())
  title     String
  desc      String              @default("")
  resources Olympiad_Resource[]
}

model Olympiad_Resource {
  id         Int      @id @default(autoincrement())
  title      String
  desc       String   @default("")
  filename   String
  olympiad   Olympiad @relation(fields: [olympiadId], references: [id])
  olympiadId Int
}
