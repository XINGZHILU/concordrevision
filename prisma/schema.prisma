generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model User {
    id                 String              @id @default(cuid())
    email              String              @unique
    firstname          String?
    lastname           String?
    teacher            Boolean             @default(false)
    upload_permission  Boolean             @default(false)
    year               Int                 @default(-1)
    posts              Post[]
    notes              Note[]
    olympiad_resources Olympiad_Resource[]
    red                Int[]
    amber              Int[]
    green              Int[]
    ppq_records        PastPaperRecord[]
}

model Subject {
    id          Int               @id @default(autoincrement())
    title       String
    desc        String
    level       Int // 0 = F3, 1 = F4, etc.
    notes       Note[]
    tests       Test[]
    ppq_records PastPaperRecord[]
}

model Test {
    id        Int      @id @default(autoincrement())
    title     String
    type      Int      @default(0) // 0 = Sat Test, 1 = EOT Exam, 2 = External Exam
    subject   Subject  @relation(fields: [subjectId], references: [id])
    subjectId Int
    desc      String   @default("")
    topics    String[]
    notes     Note[]
    date      DateTime @default(now()) @db.Date
}

model Activity {
    id    Int    @id @default(autoincrement())
    title String
    desc  String @default("")
    posts Post[]
}

model Note {
    id        Int           @id @default(autoincrement())
    title     String
    subject   Subject       @relation(fields: [subjectId], references: [id])
    subjectId Int
    desc      String        @default("")
    author    User          @relation(fields: [authorId], references: [id])
    authorId  String
    type      Int           @default(2) // 0 = Internal Exam Note, 1 = External Exam, 2 = Other
    test      Test?         @relation(fields: [testId], references: [id])
    testId    Int?
    pinned    Boolean       @default(false)
    colour    Int           @default(0) // 0 = green, 1 = amber, 2 = red
    approved  Boolean       @default(false)
    files     StorageFile[]
}

model Post {
    id         Int       @id @default(autoincrement())
    title      String
    content    String?
    published  Boolean   @default(false)
    author     User      @relation(fields: [authorId], references: [id])
    authorId   String
    Activity   Activity? @relation(fields: [activityId], references: [id])
    activityId Int?
}

model Olympiad {
    id                Int                 @id @default(autoincrement())
    title             String
    area              String
    links             String[]
    link_descriptions String[]
    desc              String              @default("")
    resources         Olympiad_Resource[]
}

model Olympiad_Resource {
    id         Int           @id @default(autoincrement())
    title      String
    desc       String        @default("")
    olympiad   Olympiad      @relation(fields: [olympiadId], references: [id])
    olympiadId Int
    author     User          @relation(fields: [authorId], references: [id])
    authorId   String
    type       Int           @default(0) // 0 = Past Paper, 1 = Solution, 2 = Other
    files      StorageFile[]
    approved   Boolean       @default(false)
}

model StorageFile {
    id                Int                @id @default(autoincrement())
    filename          String
    type              String             @default("pdf")
    path              String
    note              Note?              @relation(fields: [noteId], references: [id])
    noteId            Int?
    olympiad_resource Olympiad_Resource? @relation(fields: [olympiadId], references: [id])
    olympiadId        Int?
}

model PastPaperRecord {
    id              String  @id @default(cuid())
    name            String
    user            User    @relation(fields: [userId], references: [id])
    userId          String
    subject         Subject @relation(fields: [subjectId], references: [id])
    subjectId       Int
    specimen        Boolean @default(true)
    start_year      Int     @default(2015)
    end_year        Int     @default(2025)
    paper_count     Int     @default(3)
    papers_finished Int[]
    paper_marks     Int[]
    max_marks       Int[]
}
